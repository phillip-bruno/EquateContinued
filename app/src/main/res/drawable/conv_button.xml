<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorPrimary">
    <item>
        <selector>
            <!-- Pressed = half clicked; selected = click down and up (radio button) -->
            <item android:drawable="@drawable/conv_button_pressed" android:state_pressed="true" android:state_selected="true" />
            <item android:drawable="@drawable/conv_button_pressed" android:state_pressed="true" android:state_selected="false" />
            <item android:drawable="@drawable/conv_button_selected" android:state_pressed="false" android:state_selected="true" />
            <item android:drawable="@drawable/conv_button_normal" android:state_pressed="false" android:state_selected="false" />
        </selector>
    </item>
</ripple>
