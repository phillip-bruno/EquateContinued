<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Hover used to give convert buttons accent before convert -->
    <item android:color="?attr/colorPrimary" android:state_hovered="true" android:state_pressed="false" />

    <!-- Pressed = half clicked; selected = (only for units) unit selected -->
    <item android:color="?attr/colorOnPrimaryContainer" android:state_pressed="true" android:state_selected="true" />
    <item android:color="?attr/colorOnPrimaryContainer" android:state_pressed="true" android:state_selected="false" />
    <item android:color="?attr/colorOnSecondaryContainer" android:state_pressed="false" android:state_selected="true" />
    <item android:color="?attr/colorOnSurface" android:state_pressed="false" android:state_selected="false" />

</selector>
